# Environment variables example
# Copy this file to .env.local and configure for your environment

# Base URL para requests desde el frontend
API_URL=http://localhost:3000

# Para producción en Dokploy, configura:
# API_URL=https://api.tudominio.com
# WEB_URL=https://www.tudominio.com

# Puerto para la API
PORT=3000

# Host para la API
HOST=0.0.0.0

# Node environment
NODE_ENV=development
