---
import Layout from "../layouts/layout.astro";
import { API_URL } from "../consts";

const res = await fetch(`${API_URL}/oportunidades-laborales`);
const oportunidades: OportunidadLaboral[] = await res.json();
interface OportunidadLaboral {
	year: string;
	items: OportunidadLaboralItem[];
}

interface OportunidadLaboralItem {
	text: string;
	href: string;
}
---

<Layout>
	<main>
		{
			oportunidades.length === 0 ? (
				<p>No hay oportunidades laborales por el momento.</p>
			) : (
				oportunidades.map((item) => (
					<article>
						<header>
							<h2>{item.year}</h2>
						</header>
						<ul>
							{item.items.map((subitem) => (
								<li>
									<a
										href={subitem.href}
										target="_blank"
										rel="noopener noreferrer"
									>
										{subitem.text}
									</a>
								</li>
							))}
						</ul>
					</article>
				))
			)
		}
	</main>
</Layout>