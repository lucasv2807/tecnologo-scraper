---
import MateriaLink from "./MateriaLink.astro";
const { materia } = Astro.params;
const { inicio } = Astro.props;
---
<div class="column">
    <nav>
        <div class="internal-links column">
            <MateriaLink href={`/clases/${materia}/${inicio}`}>Inicio</MateriaLink>
            <MateriaLink href={`/clases/${materia}/${inicio}/material`}>Material</MateriaLink>
            <MateriaLink href={`/clases/${materia}/${inicio}/docentes`}>Docentes</MateriaLink>
            <MateriaLink href={`/clases/${materia}/${inicio}/resultados`}>Resultados</MateriaLink>
        </div>
    </nav>
</div>
<style>
    nav {
        background-color: var(--color-background);
        padding: 1rem;
        border-bottom: 1px solid var(--color-border);
    }
    .internal-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .column {
        display: flex;
        max-width: 320px;
        flex-direction: column;
        height: 100vh;
        position: fixed;
    }
</style>